# Resend API key — used by the contact form on / to send messages to niko@junttila.dev.
# Sign up at https://resend.com (free tier: 100 emails/day) and paste the key below.
# Sender domain `junttila.dev` is verified in Resend; form sends from contact@junttila.dev.
RESEND_API_KEY=

# Moonshot AI (Kimi) API key — powers the streaming chat demo on /ai.
# Get a key from https://platform.moonshot.ai/ . Without it, the /ai page returns an error.
# The model name is hardcoded in src/routes/ai/+server.ts (no env var needed).
MOONSHOT_API_KEY=
